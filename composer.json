{
    "name": "apntalk/esl-core",
    "description": "Framework-agnostic, transport-neutral, typed FreeSWITCH ESL protocol library for PHP with replay-safe protocol primitives",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "freeswitch",
        "esl",
        "event-socket",
        "protocol",
        "telephony"
    ],
    "authors": [
        {
            "name": "RA",
            "email": "ronniel.castanito@apntelecom.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.58"
    },
    "autoload": {
        "psr-4": {
            "Apntalk\\EslCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Apntalk\\EslCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "unit": "phpunit --no-coverage --testsuite Unit",
        "contract": "phpunit --no-coverage --testsuite Contract",
        "integration": "phpunit --no-coverage --testsuite Integration",
        "test": "phpunit --no-coverage",
        "smoke": "phpunit --no-coverage tests/Integration/SmokeTest.php",
        "chaos": "phpunit --no-coverage tests/Integration/ProtocolChaosTest.php",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff --sequential",
        "check": [
            "@cs-check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
